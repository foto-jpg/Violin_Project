# Docker volume name shared between backend and audiveris subprocess
DATA_VOLUME_NAME=omr-demo-data

# Audiveris Docker image name (built via: docker compose --profile build-only build audiveris)
AUDIVERIS_IMAGE=violin-checker-audiveris:latest

# Max upload size in MB
MAX_UPLOAD_MB=50

# Job timeout in seconds
JOB_TIMEOUT_SEC=600
